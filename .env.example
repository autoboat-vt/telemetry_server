# Cloudflare Tunnel configuration for the Autoboat telemetry server.
#
# Copy this file to .env and fill in the values. Cloudflare Tunnel makes an
# OUTBOUND connection to Cloudflare's edge, so no inbound ports need to be
# open on the host (works behind NAT, CGNAT, or a firewall). Cloudflare
# terminates TLS at the edge — no nginx or certbot is needed.

# Production domain (apex) and www subdomain. Both are routed by cloudflared
# to the telemetry-prod container.
DOMAIN=vt-autoboat-telemetry.uk

# Subdomain used for the testing instance. Routed to telemetry-test.
# The original host-based setup used port 8443 for testing; with a tunnel we
# use a hostname instead since tunnels route by hostname, not port.
TESTING_DOMAIN=test.vt-autoboat-telemetry.uk

# --- Dashboard-managed tunnel (recommended) ---
#
# 1. Go to https://one.dash.cloudflare.com/ -> Networks -> Tunnels -> Create
# 2. Create a tunnel (name it e.g. "autoboat"). Copy the install token below.
# 3. Under "Public Hostnames" add:
#        vt-autoboat-telemetry.uk      -> HTTP -> telemetry-prod:8000
#        www.vt-autoboat-telemetry.uk  -> HTTP -> telemetry-prod:8000
#        test.vt-autoboat-telemetry.uk -> HTTP -> telemetry-test:6001
#    (the DNS CNAMEs are added automatically)
# 4. Leave USE_CONFIG_FILE=0 and TUNNEL_ID blank.
#
# Also store this token as a GitHub ORGANIZATION VARIABLE named TUNNEL_TOKEN
# (not a secret): org Settings -> Actions -> Variables -> New organization
# variable. Set "Access" to "Selected repositories" and pick this repo only.
# Org variables are plaintext (visible in the Actions UI to anyone with read
# access to a repo it's shared with), so any team member can grab the token
# when provisioning a new host. Trade-off: it is NOT masked, so anyone with
# repo read access can read it. If the repo is ever compromised, rotate the
# token in Cloudflare immediately.
# In workflows it's referenced as ${{ vars.TUNNEL_TOKEN }} (note: vars, not
# secrets). When you rotate the token in Cloudflare, update BOTH the org
# variable and this file on the host.
TUNNEL_TOKEN=replace-me-with-your-cloudflare-tunnel-token
USE_CONFIG_FILE=0
TUNNEL_ID=

# --- File-managed tunnel (optional, alternative to dashboard) ---
#
# If you prefer to manage routing locally instead of in the dashboard:
#   1. Install cloudflared locally and run:  cloudflared tunnel create autoboat
#   2. Copy the resulting <UUID>.json credentials file to
#      docker/cloudflared/<UUID>.json
#   3. Set TUNNEL_ID=<UUID> and USE_CONFIG_FILE=1 below, and leave
#      TUNNEL_TOKEN blank.
#   4. Routing is read from docker/cloudflared/config.yml.
#   5. Add DNS CNAMEs:
#        cloudflared tunnel route dns autoboat vt-autoboat-telemetry.uk
#        cloudflared tunnel route dns autoboat www.vt-autoboat-telemetry.uk
#        cloudflared tunnel route dns autoboat test.vt-autoboat-telemetry.uk
#
# (leave the lines below commented for the dashboard-managed flow)
# USE_CONFIG_FILE=1
# TUNNEL_ID=00000000-0000-0000-0000-000000000000

# --- Tailscale (optional, for SSH access to the host) ---
#
# No env vars needed here — the OAuth credentials are baked into the custom
# tailscale image at build time. See docker/README.md, "SSH access via
# Tailscale" for setup (one-time `docker login ghcr.io`, then
# `docker compose --profile tailscale up -d`).
